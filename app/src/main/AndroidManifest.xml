<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Permissions — see TECH_DESIGN.md §Alarms
      and §Two-tier lookahead for justification of each.
    -->

    <!-- Exact alarms for sunrise/Parana timing. USE_EXACT_ALARM is the Play-Store-safe
         variant for "calendar / alarm clock" use cases; we'll apply with a religious-
         observance justification. Fall back to SCHEDULE_EXACT_ALARM on older devices. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Post notifications (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Location: precise for sunrise calculation, background for geofence-triggered
         travel detection (Tier 2 recompute). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Re-arm alarms on reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery optimization whitelist prompt. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Foreground service for reliable background work on API 34+. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Vibration for ritual alarm patterns. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock for alarm receivers. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".NavPanchangApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NavPanchang"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NavPanchang">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Boot receiver: re-arm all pending alarms after device restart. -->
        <receiver
            android:name=".alarms.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Timezone / locale change receiver — see §Traveling wall-clock in the plan. -->
        <receiver
            android:name=".alarms.LocaleChangeReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.LOCALE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Alarm receiver — routes to notification channels by AlarmKind. -->
        <receiver
            android:name=".alarms.AlarmReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Geofence receiver for Tier 2 travel detection. -->
        <receiver
            android:name=".location.GeofenceBroadcastReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- WorkManager is configured via NavPanchangApp (Configuration.Provider) with Hilt. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
