<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ data extraction rules. Mirror backup_rules.xml. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="navpanchang.db" />
        <include domain="sharedpref" path="user_prefs.xml" />
        <exclude domain="file" path="ephe/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="navpanchang.db" />
        <include domain="sharedpref" path="user_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
