<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules — explicit allowlist for what survives a phone migration.

  Subscriptions and user preferences ARE backed up (so a phone migration
  preserves the user's choices). The Swiss Ephemeris cache (filesDir/ephe/)
  is intentionally NOT listed: when only database + sharedpref are included,
  every other domain (file, external, root, etc.) is excluded by default.
  We previously had an explicit `<exclude domain="file" path="ephe/" />` here,
  but lint flags that as `[FullBackupContent] not in an included path` because
  the `file` domain isn't included to begin with — the exclude is redundant
  and confusing.

  The .se1 files are reinstalled fresh from APK assets on first launch via
  EphemerisAssetInstaller, so excluding them costs nothing.
-->
<full-backup-content>
    <include domain="database" path="navpanchang.db" />
    <include domain="sharedpref" path="user_prefs.xml" />
</full-backup-content>
